        <mxCell id="1" parent="0" />
        <mxCell id="5qDtxqT_W-maYSFxOuYL-11" parent="1" style="swimlane;whiteSpace=wrap;html=1;" value="Impact Level" vertex="1">
          <mxGeometry height="750" width="790" x="30" y="40" as="geometry" />
        </mxCell>
        <mxCell id="5qDtxqT_W-maYSFxOuYL-12" parent="5qDtxqT_W-maYSFxOuYL-11" style="fillColor=#ff0000;strokeColor=#000000;strokeWidth=1;" value="5 Severe" vertex="1">
          <mxGeometry height="120" width="200" x="30" y="30" as="geometry" />
        </mxCell>
        <mxCell id="5qDtxqT_W-maYSFxOuYL-13" parent="5qDtxqT_W-maYSFxOuYL-11" style="fillColor=#ff0000;strokeColor=#000000;strokeWidth=1;align=left;" value="Net Financial Impact: Greater than SAR 1M.&#xa;Strategic Growth: No growth or Negative growth rate.&#xa;Operational Impact: Potential of operational activities not conducted.&#xa;Reputation Impact: Significant and sustained adverse international media coverage.&#xa;Staff Impact: &gt; 50% of staff significantly affected." vertex="1">
          <mxGeometry height="120" width="500" x="250" y="30" as="geometry" />
        </mxCell>
        <mxCell id="5qDtxqT_W-maYSFxOuYL-14" parent="5qDtxqT_W-maYSFxOuYL-11" style="fillColor=#b22222;strokeColor=#000000;strokeWidth=1;" value="4 High" vertex="1">
          <mxGeometry height="120" width="200" x="30" y="170" as="geometry" />
        </mxCell>
        <mxCell id="5qDtxqT_W-maYSFxOuYL-15" parent="5qDtxqT_W-maYSFxOuYL-11" style="fillColor=#b22222;strokeColor=#000000;strokeWidth=1;align=left;" value="Net Financial Impact: Greater than SAR 500K but less than SAR 1M.&#xa;Strategic Growth: Significant decline in growth.&#xa;Operational Impact: High impact on operational activities.&#xa;Reputation Impact: Significant adverse national media coverage.&#xa;Staff Impact: 20% to 50% of staff significantly affected." vertex="1">
          <mxGeometry height="120" width="500" x="250" y="170" as="geometry" />
        </mxCell>
        <mxCell id="5qDtxqT_W-maYSFxOuYL-16" parent="5qDtxqT_W-maYSFxOuYL-11" style="fillColor=#ffa500;strokeColor=#000000;strokeWidth=1;" value="3 Significant" vertex="1">
          <mxGeometry height="120" width="200" x="30" y="310" as="geometry" />
        </mxCell>
        <mxCell id="5qDtxqT_W-maYSFxOuYL-17" parent="5qDtxqT_W-maYSFxOuYL-11" style="fillColor=#ffa500;strokeColor=#000000;strokeWidth=1;align=left;" value="Net Financial Impact: SAR 0 but less than SAR 5K.&#xa;Strategic Growth: Minimum impact on growth.&#xa;Operational Impact: No or immaterial impact on operations.&#xa;Reputation Impact: Minimal impact to customer base.&#xa;Staff Impact: &lt; 1% of staff affected." vertex="1">
          <mxGeometry height="120" width="500" x="250" y="310" as="geometry" />
        </mxCell>
        <mxCell id="5qDtxqT_W-maYSFxOuYL-18" parent="5qDtxqT_W-maYSFxOuYL-11" style="fillColor=#ffff00;strokeColor=#000000;strokeWidth=1;" value="2 Medium" vertex="1">
          <mxGeometry height="120" width="200" x="30" y="450" as="geometry" />
        </mxCell>
        <mxCell id="5qDtxqT_W-maYSFxOuYL-19" parent="5qDtxqT_W-maYSFxOuYL-11" style="fillColor=#ffff00;strokeColor=#000000;strokeWidth=1;align=left;" value="Net Financial Impact: SAR 50K but less than SAR 500K.&#xa;Strategic Growth: Major decline in growth.&#xa;Operational Impact: Moderate impact on operational activities.&#xa;Reputation Impact: Adverse media coverage at regional/local level.&#xa;Staff Impact: 10% to 20% of staff significantly affected." vertex="1">
          <mxGeometry height="120" width="500" x="250" y="450" as="geometry" />
        </mxCell>
        <mxCell id="5qDtxqT_W-maYSFxOuYL-20" parent="5qDtxqT_W-maYSFxOuYL-11" style="fillColor=#00ff00;strokeColor=#000000;strokeWidth=1;" value="1 Minor" vertex="1">
          <mxGeometry height="120" width="200" x="30" y="590" as="geometry" />
